# TerraPay UAT Sandbox Credentials
TERRAPAY_USERNAME=your_username_here
TERRAPAY_PASSWORD=your_password_here

# Set to true if the password provided above is already a SHA-256 hash.
# If false, the SDK will automatically hash the password.
TERRAPAY_PASSWORD_HASHED=false

TERRAPAY_ORIGIN_COUNTRY=CA
TERRAPAY_ENVIRONMENT=Sandbox
TERRAPAY_MAX_RETRIES=3

# Optional: RSA Public key used for PAN encryption (Accounts.getPanStatus)
# TERRAPAY_PUBLIC_KEY='-----BEGIN PUBLIC KEY----- ... -----END PUBLIC KEY-----'


# SSH Proxy Tunnel Configuration (Optional, for IP-allowlisted networks)
# Option 1: Full SSH connect string
# SSH_CONNECT=deploy@127.0.0.1

# Option 2: Split parameters
# SSH_USER=root
# SSH_HOST=127.0.0.1
# SSH_PORT=22
# SSH_KEY=~/.ssh/id_rsa

# Port SOCKS5 listens on (maps to ssh -D <port>)
SOCKS_PORT=1080

# Comma-separated list of host suffixes to route through the tunnel
SOCKS_PROXY_HOSTS=terrapay.com

# Cap/disable response body logging (default: 2000 chars; 0 = unlimited)
SOCKS_PROXY_BODY_MAX=2000

# Pin the remote host key instead of trust-on-first-connect (accept-new)
# SSH_KNOWN_HOSTS_FILE=/Users/your_user/.ssh/known_hosts
SSH_STRICT_HOST_KEY_CHECKING=yes
